#!/bin/bash

# --- Configuration ---
# The directory where the daily backups will be stored
BACKUP_DIR="/home/user/passwd_backups" 
# Number of days to keep the backup files
RETENTION_DAYS=2 
# --- End Configuration ---

# Ensure the backup directory exists
mkdir -p "$BACKUP_DIR"

# Get the current date in YYYY-MM-DD format
CURRENT_DATE=$(date +%Y-%m-%d)
OUTPUT_FILE="$BACKUP_DIR/passwd_fields_$CURRENT_DATE.txt"

echo "Starting backup for $CURRENT_DATE..."

# Extract first and third fields from /etc/passwd and save to the output file
# -d ':' specifies ':' as the delimiter
# -f 1,3 specifies to extract fields 1 and 3
if awk -F':' '{print $1, $3}' /etc/passwd > "$OUTPUT_FILE"; then
    echo "Successfully saved first and third fields to: $OUTPUT_FILE"
else
    echo "Error: Failed to process /etc/passwd or write to $OUTPUT_FILE"
    exit 1
fi

# --- Cleanup old backups ---
echo "Cleaning up old backups..."

# Find files older than RETENTION_DAYS and delete them
# The find command searches in BACKUP_DIR
# -type f ensures we only look at files
# -mtime +N finds files modified more than N days ago (N = RETENTION_DAYS - 1)
# -delete removes the found files
if find "$BACKUP_DIR" -type f -name "passwd_fields_*.txt" -mtime +"$((RETENTION_DAYS - 1))" -delete; then
    echo "Old backups older than $RETENTION_DAYS days have been removed."
else
    echo "No old backups to remove or an error occurred during cleanup."
fi

echo "Backup process completed."
exit 0
