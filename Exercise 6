#!/bin/bash

# === Configuration ===
USER_HOME="$HOME"
BACKUP_DIR="$HOME/backups"
TIMESTAMP=$(date +%Y-%m-%d_%H-%M-%S)
BACKUP_FILE="$BACKUP_DIR/home_backup_$TIMESTAMP.tar.gz"
RETENTION_DAYS=5     # how many days to keep backups
# =====================

# Ensure backup directory exists
mkdir -p "$BACKUP_DIR"

echo "Creating home directory backup at logout..."

# Create the backup archive
# The --exclude prevents re‑including the backup folder itself
tar -czf "$BACKUP_FILE" --exclude="$BACKUP_DIR" -C "$USER_HOME" .

# Check status and report
if [ $? -eq 0 ]; then
    echo "Backup completed: $BACKUP_FILE"
else
    echo "Backup failed!" >&2
fi

# Clean old backups
find "$BACKUP_DIR" -type f -name "home_backup_*.tar.gz" -mtime +$((RETENTION_DAYS - 1)) -delete

echo "Old backups older than $RETENTION_DAYS days removed (if any)."
